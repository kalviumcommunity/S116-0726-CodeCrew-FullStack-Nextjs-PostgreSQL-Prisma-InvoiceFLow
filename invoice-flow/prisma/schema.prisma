generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UploadStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum InvoiceStatus {
  PROCESSING
  MATCH
  MISMATCH
  FAILED
}

model Upload {
  id             String         @id @default(uuid()) @db.Uuid
  fileName       String
  uploadDate     DateTime       @default(now())
  status         UploadStatus    @default(PENDING)
  totalRows      Int
  successfulRows Int            @default(0)
  failedRows     Int            @default(0)
  invoices       Invoice[]

  @@index([status])
  @@index([uploadDate])
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  invoiceNumber String
  customerName  String
  invoiceDate   DateTime
  amount        Decimal       @db.Decimal(12, 2)
  status        InvoiceStatus @default(PROCESSING)
  errorMessage  String?
  uploadId      String        @db.Uuid
  upload        Upload        @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
  @@index([invoiceNumber])
  @@index([status])
}